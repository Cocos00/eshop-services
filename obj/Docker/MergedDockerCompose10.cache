name: dockercompose3047534284981884440
services:
  catalog.api:
    build:
      context: C:\Microservices Net Core\eshop-services\src\Service\Catalog\Catalog.API
      dockerfile: Dockerfile
    container_name: catalog.api
    depends_on:
      catalogdb:
        condition: service_started
        required: true
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ConnectionStrings__CatalogDb: Host=catalogdb;Port=5432;Database=CatalogDb;Username=postgres;Password=postgres;
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        published: "8081"
        protocol: tcp
  catalogdb:
    container_name: catalogdb
    environment:
      POSTGRES_DB: CatalogDb
      POSTGRES_PASSWORD: postgres
      POSTGRES_USER: postgres
    image: postgres:15
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5433"
        protocol: tcp
    restart: always
    volumes:
      - type: volume
        source: postgres_catalog
        target: /var/lib/postgresql/data
        volume: {}
      - type: volume
        source: postgres_catalog
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: dockercompose3047534284981884440_default
volumes:
  postgres_catalog:
    name: dockercompose3047534284981884440_postgres_catalog